<svg viewBox="0 0 900 250" width="900" height="250" xmlns="http://www.w3.org/2000/svg" fill="none">
  <defs>
    <!-- animated background gradient -->
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#1a1b26">
        <animate attributeName="stop-color" values="#1a1b26;#24283b;#1f2335;#1a1b26" dur="9s" repeatCount="indefinite"/>
      </stop>
      <stop offset="100%" stop-color="#24283b">
        <animate attributeName="stop-color" values="#24283b;#292e42;#1a1b26;#24283b" dur="9s" repeatCount="indefinite"/>
      </stop>
    </linearGradient>

    <!-- shimmering text gradient -->
    <linearGradient id="shine" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#7aa2f7"/>
      <stop offset="50%" stop-color="#c0caf5"/>
      <stop offset="100%" stop-color="#bb9af7"/>
      <animateTransform attributeName="gradientTransform" type="translate" values="-1 0; 1 0; -1 0" dur="5s" repeatCount="indefinite"/>
    </linearGradient>

    <radialGradient id="glow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#7aa2f7" stop-opacity="0.45"/>
      <stop offset="100%" stop-color="#7aa2f7" stop-opacity="0"/>
    </radialGradient>

    <style>
      @keyframes float {
        0%,100% { transform: translateY(0px); opacity:.25; }
        50%     { transform: translateY(-22px); opacity:.9; }
      }
      @keyframes pulse {
        0%,100% { transform: scale(1);   opacity:.55; }
        50%     { transform: scale(1.25); opacity:.9; }
      }
      @keyframes drift {
        0%   { transform: translateX(0); }
        100% { transform: translateX(-180px); }
      }
      .p     { animation: float 6s ease-in-out infinite; }
      .glowc { animation: pulse 4s ease-in-out infinite; transform-origin: 230px 120px; }
      .wave  { animation: drift 8s linear infinite; }
    </style>
  </defs>

  <!-- background -->
  <rect width="900" height="250" rx="22" fill="url(#bg)"/>

  <!-- moving wave band -->
  <g class="wave" opacity="0.18">
    <path d="M0 210 Q 90 185 180 210 T 360 210 T 540 210 T 720 210 T 900 210 T 1080 210 V250 H0 Z" fill="#7aa2f7"/>
  </g>
  <g class="wave" opacity="0.12" style="animation-duration:11s">
    <path d="M0 222 Q 90 200 180 222 T 360 222 T 540 222 T 720 222 T 900 222 T 1080 222 V250 H0 Z" fill="#bb9af7"/>
  </g>

  <!-- floating particles -->
  <g fill="#7aa2f7">
    <circle class="p" cx="70"  cy="60"  r="4" style="animation-delay:-0.4s"/>
    <circle class="p" cx="140" cy="180" r="3" style="animation-delay:-1.6s" fill="#bb9af7"/>
    <circle class="p" cx="320" cy="50"  r="3" style="animation-delay:-2.4s"/>
    <circle class="p" cx="410" cy="200" r="4" style="animation-delay:-3.1s" fill="#9ece6a"/>
    <circle class="p" cx="500" cy="70"  r="3" style="animation-delay:-0.9s" fill="#bb9af7"/>
    <circle class="p" cx="600" cy="40"  r="4" style="animation-delay:-2.0s"/>
    <circle class="p" cx="640" cy="210" r="3" style="animation-delay:-3.6s" fill="#e0af68"/>
    <circle class="p" cx="800" cy="190" r="4" style="animation-delay:-1.2s" fill="#bb9af7"/>
    <circle class="p" cx="850" cy="80"  r="3" style="animation-delay:-2.8s"/>
    <circle class="p" cx="250" cy="220" r="3" style="animation-delay:-0.2s" fill="#7dcfff"/>
  </g>

  <!-- pulsing glow behind avatar circle -->
  <circle class="glowc" cx="230" cy="120" r="80" fill="url(#glow)"/>

  <!-- orbiting tech dots on the right -->
  <g transform="translate(760 125)">
    <circle r="46" fill="none" stroke="#414868" stroke-width="1" stroke-dasharray="4 4"/>
    <g>
      <animateTransform attributeName="transform" type="rotate" from="0 0 0" to="360 0 0" dur="14s" repeatCount="indefinite"/>
      <circle cx="46"   cy="0"   r="7" fill="#9b59b6"/>  <!-- C# -->
      <circle cx="-46"  cy="0"   r="7" fill="#f05138"/>  <!-- Swift -->
      <circle cx="0"    cy="46"  r="7" fill="#3178c6"/>  <!-- TypeScript -->
      <circle cx="0"    cy="-46" r="7" fill="#61dafb"/>  <!-- React -->
      <circle cx="33"   cy="33"  r="6" fill="#e76f00"/>  <!-- Java -->
      <circle cx="-33"  cy="-33" r="6" fill="#336791"/>  <!-- Postgres -->
    </g>
    <circle r="10" fill="#1a1b26" stroke="#7aa2f7" stroke-width="2"/>
  </g>

  <!-- avatar-style monogram circle -->
  <circle cx="230" cy="120" r="46" fill="#1a1b26" stroke="#7aa2f7" stroke-width="2"/>
  <text x="230" y="135" font-family="'Fira Code', monospace" font-size="34" font-weight="700" fill="#7aa2f7" text-anchor="middle">&lt;/&gt;</text>

  <!-- name with shimmer -->
  <text x="330" y="115" font-family="'Fira Code', monospace" font-size="42" font-weight="800" fill="url(#shine)">
    Jojicoder
    <animate attributeName="opacity" values="0;1" dur="1.2s" fill="freeze"/>
  </text>

  <!-- subtitle -->
  <text x="332" y="150" font-family="'Fira Code', monospace" font-size="16" fill="#a9b1d6">
    Software Engineering Student · New York
    <animate attributeName="opacity" values="0;0;1" dur="2s" fill="freeze"/>
  </text>

  <!-- blinking cursor -->
  <rect x="332" y="165" width="11" height="3" fill="#7aa2f7">
    <animate attributeName="opacity" values="1;0;1" dur="1s" repeatCount="indefinite"/>
  </rect>
  <text x="350" y="178" font-family="'Fira Code', monospace" font-size="13" fill="#565f89">
    building practical software
  </text>
</svg>
